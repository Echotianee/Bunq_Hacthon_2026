# Copy this file to .env and fill in your real keys.
# .env is gitignored — never commit it.

# bunq sandbox API key — get from POST /v1/sandbox-user-person
BUNQ_API_KEY=sandbox_replace_me

# Anthropic API key — get from https://console.anthropic.com/settings/keys
# Optional: if not set, the chat box falls back to scripted answers
ANTHROPIC_API_KEY=sk-ant-api03-replace_me